{
    "name": "auth-service",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc && cd frontend && pnpm build",
        "build:server": "tsc",
        "build:frontend": "cd frontend && pnpm build",
        "start": "node dist/index.js",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
        "test:e2e:ui": "playwright test --ui --config tests/e2e/playwright.config.ts",
        "test:e2e:docker": "docker compose -f tests/e2e/docker-compose.yml up --build --wait && playwright test --config tests/e2e/playwright.config.ts"
    },
    "dependencies": {
        "@better-auth/drizzle-adapter": "^1.5.6",
        "@better-auth/oauth-provider": "^1.5.6",
        "@better-auth/passkey": "^1.5.6",
        "@fastify/cors": "^10.0.2",
        "@fastify/static": "^8.1.0",
        "better-auth": "^1.5.6",
        "dotenv": "^16.6.1",
        "drizzle-orm": "^0.44.7",
        "fastify": "^5.4.0",
        "nodemailer": "^8.0.4",
        "postgres": "^3.4.8",
        "stripe": "^21.0.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@testcontainers/postgresql": "^11.14.0",
        "@types/node": "^22.0.0",
        "@types/nodemailer": "^7.0.11",
        "@types/supertest": "^6.0.0",
        "drizzle-kit": "^0.31.9",
        "pino-pretty": "^13.1.3",
        "supertest": "^7.0.0",
        "testcontainers": "^11.14.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^3.0.0"
    }
}