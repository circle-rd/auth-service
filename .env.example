# Server
PORT=3001
HOST=0.0.0.0

# BetterAuth
BETTER_AUTH_SECRET=        # 32 random bytes: openssl rand -base64 32
BETTER_AUTH_URL=           # Public URL e.g. https://auth.example.com

# Database
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth_secret
POSTGRES_DB=auth_service
POSTGRES_PORT=5433
POSTGRES_HOST=localhost
DATABASE_URL="postgres://auth:auth_secret@localhost:5433/auth_service"

# Bootstrap superadmin (auto-created at first startup if absent)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123!

# CORS — allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (for verification and password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Stripe (optional — billing integration)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=   # From Stripe Dashboard → Webhooks → signing secret

# OAuth social providers (optional — each requires CLIENT_ID + CLIENT_SECRET)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional
NODE_ENV=development
